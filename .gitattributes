# 모든 텍스트 파일 LF로 통일
* text=auto eol=lf

# Java / 설정 파일
*.java text eol=lf
*.gradle text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf

# 쉘 스크립트
*.sh text eol=lf
gradlew text eol=lf

# Windows 배치 파일은 CRLF 유지
*.bat text eol=crlf
gradlew.bat text eol=crlf

# 바이너리 파일
*.jar binary
*.class binary
*.png binary
*.jpg binary
